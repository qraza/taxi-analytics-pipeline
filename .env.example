# Copy to .env and fill in the values you need. All variables are optional —
# the project runs fully without any of them (local ingestion, no AI features).

# DuckDB file path used by the CLI, dashboard, and dbt profile (.ci/profiles.yml).
# Defaults to data/capstone.duckdb under the project root if unset.
DBT_DB_PATH=

# Anthropic API key — enables `datatool analyse`, the dashboard's AI tabs, and
# `datatool report --ai`. Without it those features fail gracefully.
ANTHROPIC_API_KEY=

# Azure Storage connection string for the private "raw" container — needed only
# for `scripts/load_raw.py --source azure`.
AZURE_STORAGE_CONNECTION_STRING=

# Azure Blob container name holding the raw parquet + zone CSV — needed only
# for `scripts/load_raw.py --source azure`.
CAPSTONE_AZURE_CONTAINER=

# Jira REST API v3 credentials — needed only by the jira-agent GitHub Actions
# workflow (scripts/jira_client.py), not by any user-facing code.
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_BASE_URL=
